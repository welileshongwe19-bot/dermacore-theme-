<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="#F5E8E4">
  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <title>{{ page_title }}{% if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}{% if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}</title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <!-- DermaCore Fonts: DM Sans from Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,200;0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=Cormorant+Garamond:wght@300;400&display=swap" rel="stylesheet">

  {{ content_for_header }}

  {{ 'dermacore.css' | asset_url | stylesheet_tag }}
</head>

<body class="dc-body">

  <!-- Skip to content -->
  <a class="dc-skip-link" href="#MainContent">Skip to content</a>

  <!-- Announcement Bar -->
  {% section 'announcement-bar' %}

  <!-- Header / Navigation -->
  {% section 'header' %}

  <!-- Main Content -->
  <main id="MainContent" class="dc-main" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  <!-- Footer -->
  {% section 'footer' %}

  <!-- Sticky Add to Cart (mobile) -->
  <div class="dc-sticky-atc" id="stickyAtc" aria-hidden="true">
    <div class="dc-sticky-atc__inner">
      <div class="dc-sticky-atc__info">
        <span class="dc-sticky-atc__name">DermaCore Collagen Gummies</span>
        <span class="dc-sticky-atc__price" id="stickyPrice">R599.99</span>
      </div>
      <button class="dc-btn dc-btn--rose dc-sticky-atc__btn" id="stickyAtcBtn" onclick="document.getElementById('addToCartForm')?.requestSubmit()">
        Add to Routine
      </button>
    </div>
  </div>

  <script src="{{ 'dermacore.js' | asset_url }}" defer></script>
</body>
</html>
