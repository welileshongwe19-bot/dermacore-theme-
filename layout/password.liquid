<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>DermaCore — Coming Soon</title>
  <meta name="description" content="Premium collagen peptide gummies for glowing skin, healthy hair, and strong nails. Launching soon.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,200;9..40,300;9..40,400&family=Cormorant+Garamond:wght@300;400&display=swap" rel="stylesheet">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --rose-pale:  #F5E8E4;
      --rose-light: #E8C4BC;
      --rose-mid:   #DEB8B0;
      --rose-deep:  #BC8880;
      --rose-dark:  #966058;
      --navy:       #1A1A2E;
      --white:      #FFFFFF;
    }

    html, body {
      height: 100%;
      font-family: 'DM Sans', -apple-system, sans-serif;
      -webkit-font-smoothing: antialiased;
    }

    body {
      background-color: var(--navy);
      color: var(--white);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      overflow-x: hidden;
    }

    /* ── Background glow ── */
    .dc-pw-glow {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
    }
    .dc-pw-glow::before {
      content: '';
      position: absolute;
      top: -20%;
      left: 50%;
      transform: translateX(-50%);
      width: 800px;
      height: 800px;
      background: radial-gradient(circle, rgba(188,136,128,0.18) 0%, transparent 65%);
    }
    .dc-pw-glow::after {
      content: '';
      position: absolute;
      bottom: -10%;
      right: -10%;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(222,184,176,0.1) 0%, transparent 65%);
    }

    /* ── Layout ── */
    .dc-pw-page {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 48px 24px;
      text-align: center;
    }

    /* ── Logo ── */
    .dc-pw-logo {
      margin-bottom: 56px;
    }
    .dc-pw-logo img {
      height: 64px;
      width: auto;
      max-width: 280px;
      object-fit: contain;
    }
    .dc-pw-wordmark {
      font-family: 'DM Sans', sans-serif;
      font-size: 22px;
      font-weight: 200;
      letter-spacing: 10px;
      color: var(--white);
      text-transform: uppercase;
      margin-bottom: 6px;
      display: block;
    }
    .dc-pw-tagline-brand {
      font-size: 10px;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--rose-mid);
      font-weight: 300;
    }

    /* ── Eyebrow ── */
    .dc-pw-eyebrow {
      font-size: 10px;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--rose-mid);
      margin-bottom: 20px;
      font-weight: 400;
    }

    /* ── Headline ── */
    .dc-pw-headline {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: clamp(40px, 7vw, 80px);
      font-weight: 300;
      line-height: 1.1;
      color: var(--white);
      margin-bottom: 24px;
      max-width: 640px;
    }
    .dc-pw-headline em {
      font-style: italic;
      color: var(--rose-mid);
    }

    /* ── Sub ── */
    .dc-pw-sub {
      font-size: 15px;
      font-weight: 300;
      line-height: 1.75;
      color: rgba(255,255,255,0.55);
      max-width: 440px;
      margin: 0 auto 48px;
    }

    /* ── Divider line ── */
    .dc-pw-line {
      width: 48px;
      height: 1px;
      background: var(--rose-deep);
      margin: 0 auto 40px;
      opacity: 0.6;
    }

    /* ── Form ── */
    .dc-pw-form-label {
      font-size: 10px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      margin-bottom: 16px;
      display: block;
    }

    .dc-pw-form {
      display: flex;
      gap: 0;
      max-width: 440px;
      width: 100%;
      margin: 0 auto 16px;
      border: 1px solid rgba(188,136,128,0.4);
      border-radius: 100px;
      overflow: hidden;
      background: rgba(255,255,255,0.04);
      backdrop-filter: blur(8px);
      transition: border-color 0.3s;
    }
    .dc-pw-form:focus-within {
      border-color: var(--rose-deep);
    }

    .dc-pw-input {
      flex: 1;
      padding: 16px 24px;
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      font-weight: 300;
      color: var(--white);
      background: transparent;
      border: none;
      outline: none;
      letter-spacing: 0.5px;
    }
    .dc-pw-input::placeholder {
      color: rgba(255,255,255,0.3);
    }

    .dc-pw-submit {
      padding: 14px 28px;
      background: var(--rose-deep);
      color: var(--white);
      border: none;
      font-family: 'DM Sans', sans-serif;
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      cursor: pointer;
      transition: background 0.3s;
      white-space: nowrap;
      flex-shrink: 0;
      margin: 5px;
      border-radius: 100px;
    }
    .dc-pw-submit:hover {
      background: var(--rose-dark);
    }

    .dc-pw-privacy {
      font-size: 10px;
      color: rgba(255,255,255,0.25);
      letter-spacing: 0.5px;
      margin-bottom: 64px;
    }

    /* ── Benefit pills ── */
    .dc-pw-pills {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 64px;
    }
    .dc-pw-pill {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 8px 18px;
      border: 1px solid rgba(188,136,128,0.3);
      border-radius: 100px;
      font-size: 10px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.5);
    }
    .dc-pw-pill-dot {
      width: 5px;
      height: 5px;
      background: var(--rose-mid);
      border-radius: 50%;
      flex-shrink: 0;
    }

    /* ── Success state ── */
    .dc-pw-success {
      display: none;
      max-width: 440px;
      margin: 0 auto 16px;
      padding: 16px 28px;
      background: rgba(188,136,128,0.15);
      border: 1px solid rgba(188,136,128,0.4);
      border-radius: 100px;
      font-size: 13px;
      color: var(--rose-mid);
      letter-spacing: 0.5px;
    }

    /* ── Admin login link (hidden, small) ── */
    .dc-pw-admin {
      font-size: 10px;
      color: rgba(255,255,255,0.15);
      letter-spacing: 1px;
      margin-top: 8px;
    }
    .dc-pw-admin a {
      color: rgba(255,255,255,0.2);
      text-decoration: none;
      transition: color 0.3s;
    }
    .dc-pw-admin a:hover { color: rgba(255,255,255,0.5); }

    /* ── Footer ── */
    .dc-pw-footer {
      position: relative;
      z-index: 1;
      padding: 24px;
      text-align: center;
      font-size: 10px;
      color: rgba(255,255,255,0.2);
      letter-spacing: 0.5px;
      border-top: 1px solid rgba(255,255,255,0.06);
      margin-top: auto;
    }

    /* ── Decorative rose separator ── */
    .dc-pw-separator {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      margin-bottom: 48px;
      max-width: 300px;
      margin-left: auto;
      margin-right: auto;
    }
    .dc-pw-separator-line {
      flex: 1;
      height: 1px;
      background: rgba(188,136,128,0.25);
    }
    .dc-pw-separator-icon {
      width: 6px;
      height: 6px;
      background: var(--rose-deep);
      border-radius: 50%;
      opacity: 0.6;
    }

    /* ── Mobile ── */
    @media (max-width: 480px) {
      .dc-pw-form {
        flex-direction: column;
        border-radius: 16px;
        gap: 0;
      }
      .dc-pw-submit {
        margin: 0 8px 8px;
        width: calc(100% - 16px);
        padding: 14px 24px;
      }
      .dc-pw-input { padding: 16px 20px; }
      .dc-pw-headline { font-size: 38px; }
    }
  </style>
</head>

<body>

  <div class="dc-pw-glow" aria-hidden="true"></div>

  <main class="dc-pw-page">

    <!-- Logo -->
    <div class="dc-pw-logo">
      <span class="dc-pw-wordmark">DERMACORE</span>
      <span class="dc-pw-tagline-brand">Beauty From Within</span>
    </div>

    <!-- Eyebrow -->
    <p class="dc-pw-eyebrow">Launching Soon</p>

    <!-- Headline -->
    <h1 class="dc-pw-headline">
      Your glow is<br><em>almost ready.</em>
    </h1>

    <!-- Sub -->
    <p class="dc-pw-sub">
      Premium collagen peptide gummies formulated to support glowing skin, healthy-looking hair, and stronger nails. Be the first to know when we launch.
    </p>

    <div class="dc-pw-line" aria-hidden="true"></div>

    <!-- Benefit pills -->
    <div class="dc-pw-pills" aria-label="Key benefits">
      <div class="dc-pw-pill"><span class="dc-pw-pill-dot" aria-hidden="true"></span>Glowing Skin*</div>
      <div class="dc-pw-pill"><span class="dc-pw-pill-dot" aria-hidden="true"></span>Healthy Hair*</div>
      <div class="dc-pw-pill"><span class="dc-pw-pill-dot" aria-hidden="true"></span>Strong Nails*</div>
    </div>

    <!-- Email capture -->
    <label class="dc-pw-form-label" for="pwEmail">Get early access + launch offer</label>

    {% form 'customer' %}
      <input type="hidden" name="contact[tags]" value="newsletter,dermacore-launch">
      <div class="dc-pw-form" role="group" aria-label="Email signup">
        <input
          type="email"
          id="pwEmail"
          name="contact[email]"
          class="dc-pw-input"
          placeholder="your@email.com"
          required
          aria-required="true"
          autocomplete="email"
        >
        <button type="submit" class="dc-pw-submit" name="commit">
          Notify Me
        </button>
      </div>
    {% endform %}

    {% if customer %}
      <div class="dc-pw-success" style="display:block;">
        You're on the list. We'll notify you the moment we launch.
      </div>
    {% endif %}

    <p class="dc-pw-privacy">No spam. Unsubscribe anytime. We respect your privacy.</p>

    <div class="dc-pw-separator" aria-hidden="true">
      <span class="dc-pw-separator-line"></span>
      <span class="dc-pw-separator-icon"></span>
      <span class="dc-pw-separator-line"></span>
    </div>

    <!-- Store owner login — minimal and discreet -->
    <p class="dc-pw-admin">
      Store owner? <a href="/password">Enter store</a>
    </p>

  </main>

  <footer class="dc-pw-footer">
    &copy; {{ 'now' | date: '%Y' }} DermaCore &nbsp;·&nbsp; *These statements have not been evaluated by a regulatory authority. This product is not intended to diagnose, treat, cure, or prevent any disease.
  </footer>

</body>
</html>
