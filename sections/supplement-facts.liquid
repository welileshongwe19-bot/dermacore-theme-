<section class="dc-supplement" id="supplement-facts">
  <div class="dc-supplement__inner">

    <div class="dc-supplement__header">
      <p class="dc-eyebrow">Full Transparency</p>
      <h2 class="dc-h2">What's In Every Gummy</h2>
      <div class="dc-spacer-sm"></div>
      <p class="dc-body-text" style="max-width: 520px; margin: 0 auto;">
        We believe you deserve to know exactly what you're putting in your body. No hidden ingredients. No proprietary blends with no accountability. Just clean, clearly labelled beauty support.*
      </p>
    </div>

    {% if section.settings.supplement_image != blank %}
      <div class="dc-supplement__image">
        <img
          src="{{ section.settings.supplement_image | image_url: width: 1400 }}"
          alt="DermaCore supplement facts panel — full ingredient list and nutritional information"
          loading="lazy"
        >
      </div>
    {% endif %}

    <div style="text-align: center; margin-top: 24px;">
      <p style="font-size: 12px; color: var(--text-muted); max-width: 560px; margin: 0 auto; line-height: 1.7;">
        Serving size: 2 gummies · Servings per container: 30 · Keep out of reach of children. Do not exceed recommended dose. Store in a cool, dry place. Made in a GMP-certified facility.
      </p>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Supplement Facts",
  "settings": [
    {
      "type": "image_picker",
      "id": "supplement_image",
      "label": "Supplement facts image",
      "info": "Upload the supplement facts panel with stat boxes (image 11)"
    }
  ],
  "presets": [
    {
      "name": "Supplement Facts"
    }
  ]
}
{% endschema %}
