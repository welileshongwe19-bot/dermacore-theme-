<section style="padding: 80px 24px; min-height: 60vh;">
  <div style="max-width: 800px; margin: 0 auto;">

    <h1 style="font-family: var(--font-display); font-size: 36px; font-weight: 300; color: var(--navy); margin-bottom: 40px;">Your Cart</h1>

    {% if cart.item_count == 0 %}
      <div style="text-align: center; padding: 80px 24px;">
        <p style="font-size: 18px; font-weight: 300; color: var(--text-muted); margin-bottom: 32px;">Your cart is empty.</p>
        <a href="/" class="dc-btn dc-btn--rose">Start Your Glow Ritual</a>
      </div>
    {% else %}
      <form action="/cart" method="post">

        {% for item in cart.items %}
          <div style="display: grid; grid-template-columns: 80px 1fr auto; gap: 24px; align-items: center; padding: 24px 0; border-bottom: 1px solid var(--rose-pale);">
            <div style="border-radius: 8px; overflow: hidden; background: var(--rose-pale);">
              {% if item.image %}
                <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.title }}" style="width: 80px; height: 80px; object-fit: cover;">
              {% endif %}
            </div>
            <div>
              <p style="font-size: 14px; font-weight: 400; color: var(--navy); margin-bottom: 4px;">{{ item.product.title }}</p>
              {% if item.variant.title != 'Default Title' %}
                <p style="font-size: 12px; color: var(--text-muted);">{{ item.variant.title }}</p>
              {% endif %}
              <p style="font-size: 13px; color: var(--rose-deep); margin-top: 6px;">{{ item.final_price | money }}</p>
            </div>
            <div style="text-align: right;">
              <p style="font-size: 15px; font-weight: 400; color: var(--navy);">Qty: {{ item.quantity }}</p>
              <a href="/cart/change?line={{ forloop.index }}&quantity=0" style="font-size: 11px; color: var(--text-muted); letter-spacing: 1px; text-transform: uppercase; text-decoration: underline; margin-top: 8px; display: block;">Remove</a>
            </div>
          </div>
        {% endfor %}

        <div style="padding: 32px 0; display: flex; justify-content: space-between; align-items: center;">
          <div>
            <p style="font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--text-muted); margin-bottom: 6px;">Total</p>
            <p style="font-family: var(--font-display); font-size: 28px; font-weight: 300; color: var(--navy);">{{ cart.total_price | money }}</p>
            <p style="font-size: 11px; color: var(--text-muted); margin-top: 4px;">Tax included · Shipping calculated at checkout</p>
          </div>
          <button type="submit" name="checkout" class="dc-btn dc-btn--rose" style="font-size: 12px; letter-spacing: 3px; padding: 18px 44px;">
            Checkout →
          </button>
        </div>

        <p style="font-size: 11px; color: var(--text-muted); text-align: center;">
          Free delivery on orders over R800 · Secure checkout · 30-day satisfaction promise
        </p>

      </form>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Cart",
  "presets": [
    {
      "name": "Main Cart"
    }
  ]
}
{% endschema %}
