<footer class="dc-footer" role="contentinfo">
  <div class="dc-footer__inner">

    <div class="dc-footer__top">

      <!-- Brand column -->
      <div>
        {% if section.settings.footer_logo != blank %}
          <img
            src="{{ section.settings.footer_logo | image_url: width: 120 }}"
            alt="{{ shop.name }}"
            width="60"
            height="44"
            loading="lazy"
          >
        {% else %}
          <span style="font-family: var(--font-sans); font-size: 14px; font-weight: 300; letter-spacing: 5px; color: var(--navy); text-transform: uppercase;">DERMACORE</span>
        {% endif %}
        <p class="dc-footer__brand-desc">
          Premium collagen peptide gummies designed to support glowing skin, healthy-looking hair, and strong nails. Beauty support, at the core.
        </p>
        <!-- Newsletter -->
        <div class="dc-newsletter" style="margin-top: 24px;">
          <p style="font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--navy); font-weight: 500; margin-bottom: 10px;">Join the Ritual</p>
          <form class="dc-newsletter__form" aria-label="Email newsletter signup">
            <label for="footerEmail" class="sr-only">Email address</label>
            <input
              type="email"
              id="footerEmail"
              class="dc-newsletter__input"
              placeholder="your@email.com"
              required
              aria-required="true"
            >
            <button type="submit" class="dc-btn dc-btn--rose dc-newsletter__btn">Go</button>
          </form>
        </div>
      </div>

      <!-- Shop -->
      <div>
        <p class="dc-footer__col-title">Shop</p>
        <nav class="dc-footer__links" aria-label="Shop navigation">
          <a href="/products" class="dc-footer__link">Collagen Gummies</a>
          <a href="/products" class="dc-footer__link">Subscribe &amp; Save</a>
          <a href="#reviews" class="dc-footer__link">Reviews</a>
          <a href="#faq" class="dc-footer__link">FAQ</a>
        </nav>
      </div>

      <!-- Learn -->
      <div>
        <p class="dc-footer__col-title">Learn</p>
        <nav class="dc-footer__links" aria-label="Learn navigation">
          <a href="#ingredients" class="dc-footer__link">Ingredients</a>
          <a href="#how-it-works" class="dc-footer__link">How It Works</a>
          <a href="#timeline" class="dc-footer__link">What to Expect</a>
          <a href="#supplement-facts" class="dc-footer__link">Supplement Facts</a>
        </nav>
      </div>

      <!-- Support -->
      <div>
        <p class="dc-footer__col-title">Support</p>
        <nav class="dc-footer__links" aria-label="Support navigation">
          <a href="/policies/shipping-policy" class="dc-footer__link">Shipping &amp; Returns</a>
          <a href="mailto:hello@dermacore.co.za" class="dc-footer__link">Contact Us</a>
          <a href="/policies/privacy-policy" class="dc-footer__link">Privacy Policy</a>
          <a href="/policies/terms-of-service" class="dc-footer__link">Terms of Service</a>
        </nav>

        <div class="dc-footer__social" style="margin-top: 24px;" aria-label="Social media links">
          {% if section.settings.instagram_url != blank %}
            <a href="{{ section.settings.instagram_url }}" class="dc-footer__social-link" aria-label="DermaCore on Instagram" target="_blank" rel="noopener noreferrer">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
          {% endif %}
          {% if section.settings.tiktok_url != blank %}
            <a href="{{ section.settings.tiktok_url }}" class="dc-footer__social-link" aria-label="DermaCore on TikTok" target="_blank" rel="noopener noreferrer">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.21 8.21 0 004.86 1.55V6.79a4.85 4.85 0 01-1.09-.1z"/></svg>
            </a>
          {% endif %}
          {% if section.settings.facebook_url != blank %}
            <a href="{{ section.settings.facebook_url }}" class="dc-footer__social-link" aria-label="DermaCore on Facebook" target="_blank" rel="noopener noreferrer">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          {% endif %}
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="dc-footer__bottom">
      <p class="dc-footer__copy">&copy; {{ 'now' | date: '%Y' }} DermaCore. All rights reserved.</p>
      <p class="dc-footer__disclaimer">
        *These statements have not been evaluated by a regulatory authority. This product is not intended to diagnose, treat, cure, or prevent any disease. Results may vary between individuals.
      </p>
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Footer logo (optional)"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
