<!-- Subscribe & Save delivery details modal -->
<div class="dc-sub-modal" id="dcSubModal" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="dcSubModalTitle">
  <div class="dc-sub-modal__backdrop" data-sub-modal-close></div>
  <div class="dc-sub-modal__panel">
    <button type="button" class="dc-sub-modal__close" aria-label="Close" data-sub-modal-close>&times;</button>
    <h3 class="dc-sub-modal__title" id="dcSubModalTitle">Delivery Details</h3>
    <p class="dc-sub-modal__sub">Tell us where to send your monthly DermaCore delivery. You'll then be taken to Payfast to set up secure monthly billing.</p>

    <form id="dcSubDetailsForm" novalidate>
      <div class="dc-sub-modal__grid">
        <div class="dc-sub-field">
          <label for="dcSubFirstName">Name *</label>
          <input type="text" id="dcSubFirstName" name="first_name" autocomplete="given-name" required>
        </div>
        <div class="dc-sub-field">
          <label for="dcSubLastName">Surname *</label>
          <input type="text" id="dcSubLastName" name="last_name" autocomplete="family-name" required>
        </div>
        <div class="dc-sub-field dc-sub-field--full">
          <label for="dcSubEmail">Email *</label>
          <input type="email" id="dcSubEmail" name="email" autocomplete="email" required>
        </div>
        <div class="dc-sub-field dc-sub-field--full">
          <label for="dcSubCell">Cell phone number *</label>
          <input type="tel" id="dcSubCell" name="cell" autocomplete="tel" placeholder="e.g. 082 123 4567" required>
        </div>
        <div class="dc-sub-field dc-sub-field--full">
          <label for="dcSubStreet">Street address *</label>
          <input type="text" id="dcSubStreet" name="street" autocomplete="address-line1" placeholder="Street number and name" required>
        </div>
        <div class="dc-sub-field dc-sub-field--full">
          <label for="dcSubApartment">Apartment / unit (optional)</label>
          <input type="text" id="dcSubApartment" name="apartment" autocomplete="address-line2" placeholder="e.g. Unit 4, Oak Villas">
        </div>
        <div class="dc-sub-field">
          <label for="dcSubSuburb">Suburb *</label>
          <input type="text" id="dcSubSuburb" name="suburb" required>
        </div>
        <div class="dc-sub-field">
          <label for="dcSubTown">Town / City *</label>
          <input type="text" id="dcSubTown" name="town" autocomplete="address-level2" required>
        </div>
        <div class="dc-sub-field">
          <label for="dcSubProvince">Province *</label>
          <select id="dcSubProvince" name="province" autocomplete="address-level1" required>
            <option value="" disabled selected>Select province</option>
            <option>Eastern Cape</option>
            <option>Free State</option>
            <option>Gauteng</option>
            <option>KwaZulu-Natal</option>
            <option>Limpopo</option>
            <option>Mpumalanga</option>
            <option>Northern Cape</option>
            <option>North West</option>
            <option>Western Cape</option>
          </select>
        </div>
        <div class="dc-sub-field">
          <label for="dcSubPostal">Postal code *</label>
          <input type="text" id="dcSubPostal" name="postal_code" autocomplete="postal-code" inputmode="numeric" maxlength="4" required>
        </div>
      </div>
      <p class="dc-sub-modal__error" id="dcSubError" role="alert" hidden>Please complete all required fields.</p>
      <button type="submit" class="dc-btn dc-btn--rose dc-sub-modal__submit" id="dcSubDetailsSubmit">
        Continue to Secure Payment
        <span class="dc-btn-arrow" aria-hidden="true">→</span>
      </button>
      <p class="dc-sub-modal__note">Billed monthly via Payfast · Cancel anytime</p>
    </form>
  </div>
</div>

<style>
  .dc-sub-modal { position: fixed; inset: 0; z-index: 999; display: none; }
  .dc-sub-modal.open { display: block; }
  .dc-sub-modal__backdrop { position: absolute; inset: 0; background: rgba(26, 26, 46, 0.55); }
  .dc-sub-modal__panel {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    background: #fff; border-radius: 16px; padding: 28px 26px;
    width: min(560px, calc(100vw - 32px)); max-height: calc(100vh - 48px);
    overflow-y: auto; box-shadow: 0 24px 64px rgba(26, 26, 46, 0.25);
  }
  .dc-sub-modal__close {
    position: absolute; top: 12px; right: 16px; border: none; background: none;
    font-size: 26px; line-height: 1; cursor: pointer; color: #888;
  }
  .dc-sub-modal__title { margin: 0 0 6px; font-size: 22px; color: var(--navy, #1a1a2e); }
  .dc-sub-modal__sub { margin: 0 0 18px; font-size: 14px; color: #555; }
  .dc-sub-modal__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .dc-sub-field { display: flex; flex-direction: column; }
  .dc-sub-field--full { grid-column: 1 / -1; }
  .dc-sub-field label { font-size: 12px; font-weight: 600; margin-bottom: 4px; color: var(--navy, #1a1a2e); }
  .dc-sub-field input, .dc-sub-field select {
    padding: 10px 12px; border: 1px solid #d9d9e3; border-radius: 8px; font-size: 14px;
    background: #fff; color: #222;
  }
  .dc-sub-field input:focus, .dc-sub-field select:focus { outline: 2px solid var(--rose, #e75480); border-color: transparent; }
  .dc-sub-field input.dc-invalid, .dc-sub-field select.dc-invalid { border-color: #d0342c; }
  .dc-sub-modal__error { color: #d0342c; font-size: 13px; margin: 10px 0 0; }
  .dc-sub-modal__submit { width: 100%; margin-top: 16px; }
  .dc-sub-modal__note { text-align: center; font-size: 12px; color: #777; margin: 10px 0 0; }
  @media (max-width: 480px) { .dc-sub-modal__grid { grid-template-columns: 1fr; } }
</style>
